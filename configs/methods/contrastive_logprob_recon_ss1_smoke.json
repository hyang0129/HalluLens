{
  "name": "contrastive_logprob_recon_ss1_smoke",
  "routine": "contrastive_logprob_recon_dualhead_fusion",
  "model_class": "shared_spine_dual_head",
  "model_params": {
    "trunk_dim": 512,
    "head_dim": 512,
    "head_hidden_dim": 512,
    "head_depth": 2,
    "spine_supcon_grad_scale": 0.0,
    "input_dropout": 0.3,
    "recon_seq_len": 64,
    "recon_hidden_dim": 256,
    "recon_lambda": 1.0,
    "logprob_var_threshold": 1e-4
  },
  "training": {
    "max_epochs": 1,
    "batch_size": 256,
    "lr": 1e-5,
    "temperature": 0.25,
    "sub_batch_size": 64,
    "use_infinite_index_stream": true,
    "steps_per_epoch_override": 10,
    "balanced_sampling": false,
    "grad_clip_norm": 1.0,
    "ignore_labels": [1, 0]
  },
  "data": {
    "relevant_layers": "14-29",
    "target_layers": [22, 26],
    "num_views": 2,
    "pad_length": 63,
    "preload": true,
    "include_response_logprobs": true,
    "response_logprobs_top_k": 20
  },
  "evaluation": {
    "metrics": ["knn"],
    "knn_params": {
      "k": 50,
      "metric": "euclidean",
      "calibrate_k": false,
      "max_train_size": 20000
    },
    "eval_batch_size": 256,
    "sub_batch_size": 64
  }
}
