{
  "routine": "contrastive_actvit",
  "model_class": "contrastive_actvit",
  "model_params": {
    "final_dim": 256,
    "recon_seq_len": 64,
    "recon_hidden_dim": 256,
    "recon_lambda": 1.0,
    "logprob_var_threshold": 0.0001,
    "L_p": 8,
    "N_p": 100,
    "patch_h": 2,
    "patch_w": 10,
    "d_adapter": 256,
    "d_model": 256,
    "num_heads": 8,
    "depth": 4,
    "mlp_ratio": 4.0,
    "dropout": 0.1
  },
  "training": {
    "max_epochs": 50,
    "batch_size": 64,
    "lr": 0.0001,
    "temperature": 0.25,
    "sub_batch_size": 64,
    "use_labels": true,
    "ignore_label": 0,
    "use_infinite_index_stream": true,
    "balanced_sampling": false,
    "grad_clip_norm": 1.0
  },
  "data": {
    "num_views": 2,
    "view_aug": "layer_band",
    "noise_scale": 0.1,
    "keep_frac": 0.6,
    "mask_frac": 0.5,
    "relevant_layers": "14-29"
  },
  "evaluation": {
    "metrics": [
      "knn"
    ],
    "knn_params": {
      "k": 50,
      "metric": "euclidean",
      "calibrate_k": true,
      "k_candidates": [
        50,
        100,
        200,
        500,
        1000
      ],
      "max_train_size": 200000
    },
    "eval_batch_size": 64,
    "sub_batch_size": 64,
    "flip_auroc": true
  },
  "name": "contrastive_actvit_cav2"
}